{
  "meta": {
    "lastTouchedVersion": "2026.3.15"
  },
  "update": {
    "channel": "stable",
    "checkOnStart": true,
    "auto": {
      "enabled": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 3,
              "output": 15,
              "cacheRead": 0.3,
              "cacheWrite": 3.75
            },
            "contextWindow": 200000,
            "maxTokens": 128000
          },
          {
            "id": "claude-haiku-4-5-20251001",
            "name": "Claude Haiku 4.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 0.8,
              "output": 4,
              "cacheRead": 0.08,
              "cacheWrite": 1
            },
            "contextWindow": 200000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-haiku-4-5-20251001"
        ]
      },
      "workspace": "/home/openclaw/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "10m",
        "target": "telegram"
      },
      "maxConcurrent": 10
    },
    "list": [
      {
        "id": "clawarr",
        "name": "ClaWArr",
        "workspace": "/home/openclaw/.openclaw/workspace",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6",
          "fallbacks": [
            "anthropic/claude-haiku-4-5-20251001"
          ]
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true
      }
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "commands": {
        "native": true,
        "nativeSkills": true
      },
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [],
      "groupPolicy": "allowlist",
      "groups": {},
      "dmHistoryLimit": 800,
      "chunkMode": "length",
      "streaming": "partial",
      "draftChunk": {
        "breakPreference": "paragraph"
      },
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "sticker": true
      },
      "ackReaction": "👀"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789"
      ],
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 900000
      }
    },
    "trustedProxies": [
      "10.42.0.0/16",
      "10.43.0.0/16",
      "127.0.0.1"
    ],
    "tls": {
      "enabled": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "memory": {
    "backend": "file",
    "citations": "auto"
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
